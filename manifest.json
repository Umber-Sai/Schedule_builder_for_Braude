{
  "manifest_version": 3,
  "name": "Schedule planner",
  "version": "2.0",
  "description": "Extracts lessons from web pages and displays them in a visual calendar.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["scripting"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/config.js",
        "src/utils/scaler.js",
        "src/utils/lesson-manager.js",
        "src/utils/local-storage.js",
        "src/utils/page-parser.js",
        "src/items/lesson.js",
        "src/items/legend-item.js",
        "src/objects/calendar.js",
        "src/objects/legend.js",
        "src/main.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
